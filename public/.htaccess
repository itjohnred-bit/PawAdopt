Options -Indexes
ServerSignature Off
ServerTokens Prod

<FilesMatch "^(database|email)\.php$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.ht">
    Require all denied
</FilesMatch>
<FilesMatch "\.(env|sql|bak|backup|gitignore|git|svn|log)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header unset X-Powered-By
    Header unset Server
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On
# If accessing api/ folder directly
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{REQUEST_URI} !^/includes/
RewriteCond %{REQUEST_URI} !^/config/
RewriteCond %{REQUEST_URI} !^/uploads/
# Default: route everything else through index.php
RewriteRule ^ index.php [L]

</IfModule>

<IfModule mod_mime.c>
    AddDefaultCharset UTF-8
    AddCharset UTF-8 .html .css .js .json .xml .txt
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png  "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css   "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

php_flag display_errors Off
php_value error_reporting 0
php_flag log_errors On
